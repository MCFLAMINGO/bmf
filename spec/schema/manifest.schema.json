{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmf.dev/schema/0.2.0/manifest.schema.json",
  "title": "BMF Manifest",
  "description": "A signed, content-addressed manifest for an embodied asset.",
  "type": "object",
  "required": [
    "bmf",
    "id",
    "kind",
    "mime",
    "bytes",
    "asset_hash",
    "capabilities",
    "provenance",
    "royalty_chain",
    "issued_at",
    "expires_at",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "bmf": {
      "type": "string",
      "enum": ["0.1.0", "0.2.0"],
      "description": "Spec version. New manifests SHOULD use 0.2.0; 0.1.0 remains verifiable."
    },
    "id": {
      "type": "string",
      "format": "uri",
      "description": "Stable identifier. RECOMMENDED form: bmf://<gateway-host>/asset/<opaque-id>"
    },
    "kind": {
      "type": "string",
      "enum": ["glb", "urdf", "mjcf", "policy", "dataset", "trajectory-bundle"]
    },
    "mime": {
      "type": "string"
    },
    "bytes": {
      "type": "integer",
      "minimum": 0
    },
    "asset_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+!?$"
      },
      "uniqueItems": true
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step"],
        "additionalProperties": false,
        "properties": {
          "step": {
            "type": "string",
            "description": "One of: source, rig, retexture, remesh, retarget, train, finetune, edit, or custom:<name>"
          },
          "source": { "type": "string" },
          "notes":  { "type": "string" }
        }
      }
    },
    "royalty_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recipient", "share_bps"],
        "additionalProperties": false,
        "properties": {
          "recipient": {
            "type": "string",
            "description": "DID or wallet-address URI"
          },
          "share_bps": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          }
        }
      }
    },
    "x402": {
      "type": "object",
      "required": ["price", "recipient"],
      "additionalProperties": false,
      "properties": {
        "price": {
          "type": "object",
          "required": ["amount", "currency", "chain"],
          "additionalProperties": false,
          "properties": {
            "amount":   { "type": "string" },
            "currency": { "type": "string" },
            "chain":    { "type": "string" }
          }
        },
        "recipient": { "type": "string" }
      }
    },
    "producer": {
      "type": "string",
      "description": "DID of the producer. If omitted, the gateway is the producer."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "signature": {
      "type": "object",
      "required": ["alg", "public_key", "value"],
      "additionalProperties": false,
      "properties": {
        "alg":        { "type": "string", "const": "ed25519" },
        "public_key": { "type": "string", "pattern": "^base64url:[A-Za-z0-9_-]+$" },
        "value":      { "type": "string", "pattern": "^base64url:[A-Za-z0-9_-]+$" }
      }
    }
  }
}
