{
  "name": "@mcflamingo/bmf-sdk",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://github.com/MCFLAMINGO/bmf/tree/main/sdk/typescript#readme",
  "bugs": "https://github.com/MCFLAMINGO/bmf/issues",
  "version": "0.1.0",
  "description": "BMF SDK: verify, sign, canonicalize, and hash signed manifests for embodied assets (3D characters, robot policies, URDFs, teleop datasets).",
  "license": "Apache-2.0",
  "author": "Erik Osol <erik@mcflamingo.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MCFLAMINGO/bmf.git",
    "directory": "sdk/typescript"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["bmf", "manifest", "ed25519", "signing", "3d", "glb", "robotics", "urdf", "policy", "capabilities"],
  "dependencies": {
    "@noble/ed25519": "^2.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0"
  }
}
